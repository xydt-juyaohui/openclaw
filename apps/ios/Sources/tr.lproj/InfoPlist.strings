"CFBundleDisplayName" = "$(OPENCLAW_APP_DISPLAY_NAME)";
/* OpenClaw source: "OpenClaw uses your calendars to show events and scheduling context when you enable calendar access." */
"NSCalendarsFullAccessUsageDescription" = "OpenClaw, takvim erişimini etkinleştirdiğinizde etkinlikleri ve planlama bağlamını göstermek için takvimlerinizi kullanır.";
/* OpenClaw source: "OpenClaw uses your calendars to show events and scheduling context when you enable calendar access." */
"NSCalendarsUsageDescription" = "OpenClaw, takvim erişimini etkinleştirdiğinizde etkinlikleri ve planlama bağlamını göstermek için takvimlerinizi kullanır.";
/* OpenClaw source: "OpenClaw uses your calendars to add events when you enable calendar access." */
"NSCalendarsWriteOnlyAccessUsageDescription" = "OpenClaw, takvim erişimini etkinleştirdiğinizde etkinlik eklemek için takvimlerinizi kullanır.";
/* OpenClaw source: "OpenClaw uses the camera when you scan a Gateway setup QR code or ask your paired Gateway or assistant to capture a photo or short video from this iPhone, for example to connect to your Gateway or show your assistant a document, device screen, or workspace." */
"NSCameraUsageDescription" = "OpenClaw, bir Gateway kurulum QR kodunu taradığınızda veya eşleştirilmiş Gateway'inizden ya da asistanınızdan bu iPhone'dan fotoğraf veya kısa video çekmesini istediğinizde kamerayı kullanır; örneğin Gateway'inize bağlanmak veya asistanınıza bir belge, cihaz ekranı ya da çalışma alanı göstermek için.";
/* OpenClaw source: "OpenClaw uses your contacts so you can search and reference people while using the assistant." */
"NSContactsUsageDescription" = "OpenClaw, asistanı kullanırken kişileri arayabilmeniz ve onlara referans verebilmeniz için kişilerinizi kullanır.";
/* OpenClaw source: "OpenClaw discovers and connects to your OpenClaw gateway on the local network." */
"NSLocalNetworkUsageDescription" = "OpenClaw, yerel ağdaki OpenClaw gateway'inizi keşfeder ve ona bağlanır.";
/* OpenClaw source: "OpenClaw can share your location in the background when you enable Always." */
"NSLocationAlwaysAndWhenInUseUsageDescription" = "OpenClaw, Her Zaman seçeneğini etkinleştirdiğinizde konumunuzu arka planda paylaşabilir.";
/* OpenClaw source: "OpenClaw uses your location when you allow location sharing." */
"NSLocationWhenInUseUsageDescription" = "OpenClaw, konum paylaşımına izin verdiğinizde konumunuzu kullanır.";
/* OpenClaw source: "OpenClaw uses the microphone for realtime chat, voice wake, push-to-talk, and voice notes." */
"NSMicrophoneUsageDescription" = "OpenClaw mikrofonu gerçek zamanlı sohbet, sesle uyandırma, bas-konuş ve sesli notlar için kullanır.";
/* OpenClaw source: "OpenClaw may use motion data to support device-aware interactions and automations." */
"NSMotionUsageDescription" = "OpenClaw, cihaza duyarlı etkileşimleri ve otomasyonları desteklemek için hareket verilerini kullanabilir.";
/* OpenClaw source: "OpenClaw reads your steps, sleep, resting heart rate, and workouts from the Apple Health app to create summaries you request and send them through your Gateway to your configured AI provider." */
"NSHealthShareUsageDescription" = "OpenClaw, istediğiniz özetleri oluşturmak ve bunları Gateway üzerinden yapılandırılmış AI sağlayıcınıza göndermek için Apple Sağlık uygulamasındaki adım, uyku, dinlenme kalp atış hızı ve antrenman verilerinizi okur.";
/* OpenClaw source: "OpenClaw does not write to the Apple Health app. It uses read-only data to create summaries you request and send them through your Gateway to your configured AI provider." */
"NSHealthUpdateUsageDescription" = "OpenClaw, Apple Sağlık uygulamasına veri yazmaz. İstediğiniz özetleri oluşturmak ve bunları Gateway üzerinden yapılandırılmış AI sağlayıcınıza göndermek için salt okunur verileri kullanır.";
/* OpenClaw source: "OpenClaw lets your assistant read photos you allow and lets you choose photos to share." */
"NSPhotoLibraryUsageDescription" = "OpenClaw, asistanınızın izin verdiğiniz fotoğrafları okumasını sağlar ve paylaşılacak fotoğrafları seçmenize olanak tanır.";
/* OpenClaw source: "OpenClaw uses your reminders to list, add, and complete tasks when you enable reminders access." */
"NSRemindersFullAccessUsageDescription" = "OpenClaw, anımsatıcılara erişimi etkinleştirdiğinizde görevleri listelemek, eklemek ve tamamlamak için anımsatıcılarınızı kullanır.";
/* OpenClaw source: "OpenClaw uses on-device speech recognition for talk mode and voice wake." */
"NSSpeechRecognitionUsageDescription" = "OpenClaw, konuşma modu ve sesle uyandırma için aygıt üzerinde konuşma tanımayı kullanır.";
